// INTERIOR
section.interior.section-box.none
    .container
        h2.interior__title.section-title Наш<br> интерьер
        .gallery-slider-wrapper
            // GALLERY SLIDER
            .swiper.gallery-slider
                .swiper-pagination
                .swiper-wrapper
                    .swiper-slide
                        a(href="./img/gallery/01.webp" data-fancybox="interior").gallery__img
                            img(src="./img/gallery/01.webp" alt="интерьер" width="286" height="250" loading="lazy")
                            .zoom
                                svg.svg-zoom
                                    use(href="./img/spriteSvg.svg#svg-zoom")
